      "advice": "可能需要調整劑量"
    },
    "significant_invitro": {
      "label": "顯著（試管數據）",
      "criteria": ">30% 移除率，但無活體數據",
      "advice": "可能需要調整劑量"
    },
    "insignificant_invivo": {
      "label": "不顯著（活體數據）",
